{
  "properties": [
    {
      "name": "threads.auth.app.id",
      "type": "java.lang.String",
      "description": "Threads App Id.",
      "sourceType": "com.pluxurydolo.threads.properties.ThreadsAuthProperties"
    },
    {
      "name": "threads.auth.app.secret",
      "type": "java.lang.String",
      "description": "Threads App Secret.",
      "sourceType": "com.pluxurydolo.threads.properties.ThreadsAuthProperties"
    },
    {
      "name": "threads.auth.user-id",
      "type": "java.lang.String",
      "description": "Threads User Id.",
      "sourceType": "com.pluxurydolo.threads.properties.ThreadsAuthProperties"
    },
    {
      "name": "threads.auth.redirect-uri",
      "type": "java.lang.String",
      "description": "URI редиректа после логина.",
      "sourceType": "com.pluxurydolo.threads.properties.ThreadsAuthProperties"
    },
    {
      "name": "threads.endpoint.login",
      "type": "java.lang.String",
      "description": "Эндпоинт логина.",
      "sourceType": "com.pluxurydolo.threads.properties.ThreadsEndpointProperties"
    },
    {
      "name": "threads.endpoint.redirect",
      "type": "java.lang.String",
      "description": "Эндпоинт редиректа после логина.",
      "sourceType": "com.pluxurydolo.threads.properties.ThreadsEndpointProperties"
    },
    {
      "name": "threads.endpoint.refresh-token",
      "type": "java.lang.String",
      "description": "Эндпоинт для обновления токена.",
      "sourceType": "com.pluxurydolo.threads.properties.ThreadsEndpointProperties"
    },
    {
      "name": "threads.polling.max-repeat",
      "type": "java.lang.Integer",
      "description": "Максимальное число попыток поллинга.",
      "sourceType": "com.pluxurydolo.threads.properties.ThreadsPollingProperties"
    },
    {
      "name": "threads.polling.delay",
      "type": "java.time.Duration",
      "description": "Интервал поллинга.",
      "sourceType": "com.pluxurydolo.threads.properties.ThreadsPollingProperties"
    },
    {
      "name": "threads.scheduler.refresh-token.cron",
      "type": "java.lang.String",
      "description": "Cron обновления токена."
    },
    {
      "name": "threads.scheduler.refresh-token.zone",
      "type": "java.lang.String",
      "description": "Временная зона выполнения cron по обновлению токена."
    }
  ],
  "hints": [
    {
      "name": "threads.auth.app.id",
      "values": [
        {
          "value": "${THREADS_APP_ID}"
        }
      ],
      "providers": [
        {
          "name": "any"
        }
      ]
    },
    {
      "name": "threads.auth.app.secret",
      "values": [
        {
          "value": "${THREADS_APP_SECRET}"
        }
      ],
      "providers": [
        {
          "name": "any"
        }
      ]
    },
    {
      "name": "threads.auth.user-id",
      "values": [
        {
          "value": "${THREADS_USER_ID}"
        }
      ],
      "providers": [
        {
          "name": "any"
        }
      ]
    },
    {
      "name": "threads.auth.redirect-uri",
      "values": [
        {
          "value": "http://localhost:8888${threads.redirect.url}"
        }
      ],
      "providers": [
        {
          "name": "any"
        }
      ]
    },
    {
      "name": "threads.endpoint.login",
      "values": [
        {
          "value": "/${spring.application.name}/v1/threads/login"
        }
      ],
      "providers": [
        {
          "name": "any"
        }
      ]
    },
    {
      "name": "threads.endpoint.redirect",
      "values": [
        {
          "value": "/${spring.application.name}/v1/threads/login/redirect"
        }
      ],
      "providers": [
        {
          "name": "any"
        }
      ]
    },
    {
      "name": "threads.endpoint.refresh-token",
      "values": [
        {
          "value": "/${spring.application.name}/v1/threads/token/refresh"
        }
      ],
      "providers": [
        {
          "name": "any"
        }
      ]
    },
    {
      "name": "threads.polling.max-repeat",
      "values": [
        {
          "value": "20"
        }
      ],
      "providers": [
        {
          "name": "any"
        }
      ]
    },
    {
      "name": "threads.polling.delay",
      "values": [
        {
          "value": "10s"
        }
      ],
      "providers": [
        {
          "name": "any"
        }
      ]
    },
    {
      "name": "threads.scheduler.refresh-token.cron",
      "values": [
        {
          "value": "0 0 0 * * SUN"
        }
      ],
      "providers": [
        {
          "name": "any"
        }
      ]
    },
    {
      "name": "threads.scheduler.refresh-token.zone",
      "values": [
        {
          "value": "Europe/Moscow"
        }
      ],
      "providers": [
        {
          "name": "any"
        }
      ]
    }
  ]
}
